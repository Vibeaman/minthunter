# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token

# Ethereum RPC (Alchemy recommended)
ALCHEMY_RPC=https://eth-mainnet.g.alchemy.com/v2/your_key

# Fee wallet receives FCFS/Snipe fees
FEE_WALLET=0x1d5dfc070385e6d749707fc94c4af09207d311f9

# Fee amount in ETH
FCFS_FEE_ETH=0.0002

# 32-byte hex key for AES-256 encryption (64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here
